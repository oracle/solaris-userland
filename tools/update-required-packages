# Script operates on Makefile specified on command line. It replaces the
# REQUIRED_PACKAGES found there with a list of packages supplied on stdin. It
# can convert versioned packages like runtime/python-311 to
# runtime/python-$(PYV) or $(PYVS:%=runtime/python-%).

set -eEuo pipefail

shopt -s extglob

# Location of our input Makefile we are going to change
INPUT_FILE="${1:-}"

# Hash of existing REQUIRED_PACKAGES packages found in Makefile.
# Key - package name
# Value - '.i386', '.sparc' or ''; denoting that this package is exclusive to
#    one architecture or required by both.
typeset -A EXISTING_MAKEFILE_PACKAGES

# Array of packages found by pkgdepend
typeset -a NEW_MAKEFILE_PACKAGES=()

# Hash of REQUIRED_PACKAGES found by pkgdepend. Key is versioned package name
# (for example using $(PYVER)), value is '1' when used.
typeset -A NEW_MAKEFILE_PACKAGE_MARK

function main {
	if [ -z "$INPUT_FILE" ]; then
		usage
		exit 1
	fi

	MY_ARCH=$(uname -p)
	[[ $MY_ARCH == i386 ]] && OTHER_ARCH=sparc || OTHER_ARCH=i386

	# We use prefix '.' everywhere
	MY_ARCH=.$MY_ARCH
	OTHER_ARCH=.$OTHER_ARCH

	# 1. Remember existing Makefile package spellings and arch qualifiers.
	# 2. Convert pkgdepend output to preferred Makefile spellings.
	# 3. Reinject packages that belong only to the other architecture.
	# 4. Replace the autogenerated REQUIRED_PACKAGES block.

	read-current-makefile
	read-pkgdepend-output
	inject-other-architecture-packages
	update-makefile
}

function usage {
	printf 'usage: %s MAKEFILE\n' "${0##*/}" >&2
}

# runtime/python-311 -> runtime/python-$(PYV)
# Return the Makefile spelling to use for a raw package name.
# Prefer existing a form used in current Makefile
function package-to-metapackage {
	local PACKAGE=$1
	local RET
	local CANDIDATE
	local -a CANDIDATES=()

	# pkgdepend resolve can choose either side of require-any dependencies
	# such as gcc-c-runtime and gcc-c-runtime-N. Preserve the spelling
	# already used in the Makefile when the generated package is an
	# equivalent gcc runtime package.
	case "$PACKAGE" in
		system/library/gcc/gcc-c-runtime|system/library/gcc/gcc-c\+\+-runtime)
			if [ "${EXISTING_MAKEFILE_PACKAGES[$PACKAGE]+x}" = x ]; then
				echo "$PACKAGE"
				return
			fi
			for RET in "${!EXISTING_MAKEFILE_PACKAGES[@]}"; do
				[[ $RET == "$PACKAGE"-+([0-9]) ]] && echo "$RET" && return
			done
			;;
		system/library/gcc/gcc-c-runtime-+([0-9])|system/library/gcc/gcc-c\+\+-runtime-+([0-9]))
			if [ "${EXISTING_MAKEFILE_PACKAGES[$PACKAGE]+x}" = x ]; then
				echo "$PACKAGE"
				return
			fi
			RET="${PACKAGE%-*}"
			if [ "${EXISTING_MAKEFILE_PACKAGES[$RET]+x}" = x ]; then
				echo "$RET"
				return
			fi
			;;
	esac

	case "$PACKAGE" in
		runtime/perl-+([0-9]))
			CANDIDATES=( '$(PERL_PKG)' )
			;;
		?(system/)library/python/*-+([0-9])|runtime/python-+([0-9]))
			CANDIDATES=(
				"${PACKAGE%-*}-\$(PYV)"
				"\$(PYVS:%=${PACKAGE%-*}-%)"
				"\$(subst .,,\$(PYTHON_VERSIONS:%=${PACKAGE%-*}-%))"
			)
			;;
		runtime/ruby-+([0-9]))
			CANDIDATES=( 'runtime/ruby-$(RUBY_PUPPET_NODOT_VERSION)' )
			;;
		library/perl-5/*-+([0-9]))
			CANDIDATES=( "\$(PERL_VERSIONS:5.%=${PACKAGE%-5*}-5%)" )
			;;
		*)
			echo "$PACKAGE"
			return
			;;
	esac

	for CANDIDATE in "${CANDIDATES[@]}"; do
		if [ "${EXISTING_MAKEFILE_PACKAGES[$CANDIDATE]+x}" = x ]; then
			echo "$CANDIDATE"
			return
		fi
	done

	echo "$PACKAGE"
}

function read-current-makefile {
	local LINE
	local PACKAGE

	while IFS= read -r LINE; do
		# Skip anything not being REQUIRED_PACKAGES(.i386|.sparc)? += ...
		[[ $LINE =~ ^REQUIRED_PACKAGES(\.i386|\.sparc)?[[:space:]]*\+=[[:space:]]*(.*) ]] || continue

		# Store the package into our hash with assigned architecture
		PACKAGE="${BASH_REMATCH[2]}"
		EXISTING_MAKEFILE_PACKAGES[$PACKAGE]="${BASH_REMATCH[1]}" # .i386, .sparc or empty
	done < "$INPUT_FILE"
}

function read-pkgdepend-output {
	local LINE
	local PREVIOUS_ARCH
	local VERSIONED_NEW_PACKAGE

	while IFS= read -r LINE; do
		VERSIONED_NEW_PACKAGE=$( package-to-metapackage "$LINE" )
		PREVIOUS_ARCH="${EXISTING_MAKEFILE_PACKAGES[$VERSIONED_NEW_PACKAGE]:-}"

		# The previously exclusive package to other architecture is now common
		# because pkgdepend found it here too
		if [[ $PREVIOUS_ARCH != $MY_ARCH ]]; then
			PREVIOUS_ARCH=
		fi

		NEW_MAKEFILE_PACKAGES+=( "REQUIRED_PACKAGES${PREVIOUS_ARCH} += $VERSIONED_NEW_PACKAGE" )
		NEW_MAKEFILE_PACKAGE_MARK[$VERSIONED_NEW_PACKAGE]=1
	done
}

function inject-other-architecture-packages {
	local PACKAGE

	# pkgdepend sees only the current architecture. Preserve package lines that
	# were explicitly generated for the other architecture.
	for PACKAGE in "${!EXISTING_MAKEFILE_PACKAGES[@]}"; do
		if [[ "${EXISTING_MAKEFILE_PACKAGES[$PACKAGE]}" == $OTHER_ARCH ]] && [[ -z "${NEW_MAKEFILE_PACKAGE_MARK[$PACKAGE]:-}" ]]; then
			NEW_MAKEFILE_PACKAGES+=( "REQUIRED_PACKAGES${OTHER_ARCH} += $PACKAGE" )
		fi
	done
}

function update-makefile {
	# Strip REQUIRED_PACKAGES variable from Makefile
	gsed -i '/^REQUIRED_PACKAGES/,$d' "$INPUT_FILE"

	if [ "${#NEW_MAKEFILE_PACKAGES[@]}" -gt 0 ]; then
		printf '%s\n' "${NEW_MAKEFILE_PACKAGES[@]}" | sort -k 3 -u >> "$INPUT_FILE"
	fi
}

main "$@"
