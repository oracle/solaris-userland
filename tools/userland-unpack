#
# userland-unpack - an archive unpack utility
#
# A simple program to uncompress and unpack source archive files into a target
# directory and fix permissions if requested.
#

import argparse
import os
import re
import shlex
import stat
import subprocess
import tempfile

# By default the verbose mode is off and thus verbose does nothing
verbose = lambda *a, **k: None

RUBY_VERSION_RE = re.compile(r"^[0-9]+\.[0-9]+$")
GTAR_EXTRACT = ["gtar", "-xf", "-"]


def format_commands(commands: tuple[list[str], ...]) -> str:
    """Render commands for diagnostics."""

    return " | ".join(shlex.join(command) for command in commands)


def extract_commands(filename: str) -> tuple[list[str], ...]:
    """Get commands to extract the given archive.

    Several archives are supported with following results:

      .bz2 | .tbz | .tbz2  -> /usr/bin/bzip2 -dc IN       | gtar -xf -
      .tgz | .gz           -> /usr/bin/gzip -dc IN        | gtar -xf -
      .Z                   -> /usr/bin/uncompress -c IN   | gtar -xf -
      .7z                  -> /usr/bin/7z --s IN          | gtar -xf -
      .xz                  -> /usr/bin/xz -dc IN          | gtar -xf -
      .jar                 -> /usr/bin/jar xf IN
      .zip                 -> /usr/bin/unzip -qo IN
      .gem                 -> /usr/ruby/RUBYVER/bin/gem unpack IN
      .tlz4 | .tar.lz4     -> /usr/bin/unlz4 -c           | gtar -xf -
    """

    if filename.endswith((".bz2", ".tbz", ".tbz2")):
        return (["/usr/bin/bzip2", "-dc", filename], GTAR_EXTRACT)
    elif filename.endswith((".gz", ".tgz")):
        return (["/usr/bin/gzip", "-dc", filename], GTAR_EXTRACT)
    elif filename.endswith(".Z"):
        return (["/usr/bin/uncompress", "-c", filename], GTAR_EXTRACT)
    elif filename.endswith(".7z"):
        return (["/usr/bin/7z", "--s", filename], GTAR_EXTRACT)
    elif filename.endswith(".xz"):
        return (["/usr/bin/xz", "-dc", filename], GTAR_EXTRACT)
    elif filename.endswith((".tlz4", ".tar.lz4")):
        return (["/usr/bin/unlz4", "-c", filename], GTAR_EXTRACT)
    elif filename.endswith(".jar"):
        return (["/usr/bin/jar", "xf", filename],)
    elif filename.endswith(".zip"):
        return (["/usr/bin/unzip", "-qo", filename],)
    elif filename.endswith(".gem"):
        ruby_ver = os.getenv("RUBY_VERSION")
        if not ruby_ver:
            raise RuntimeError("RUBY_VERSION environment variable is not set")
        if not RUBY_VERSION_RE.fullmatch(ruby_ver):
            raise RuntimeError(
                f"Unsupported RUBY_VERSION {ruby_ver!r}; expected <major>.<minor>"
            )
        return ([f"/usr/ruby/{ruby_ver}/bin/gem", "unpack", filename],)

    return (["/bin/cat", filename], GTAR_EXTRACT)


def extract_archive(tempdir: str, commands: tuple[list[str], ...]) -> None:
    """Extract the selected archive into a temporary directory.
    """

    if len(commands) == 1:
        subprocess.run(commands[0], cwd=tempdir, check=True)
        return
    if len(commands) != 2:
        raise RuntimeError(f"Unsupported command pipeline length: {len(commands)}")

    first, second = commands

    with subprocess.Popen(first, cwd=tempdir, stdout=subprocess.PIPE) as first_proc:
        if first_proc.stdout is None:
            raise RuntimeError("Could not capture archive stream")

        try:
            subprocess.run(second, cwd=tempdir, stdin=first_proc.stdout, check=True)
        finally:
            first_proc.stdout.close()

        if first_proc.wait() != 0:
            raise subprocess.CalledProcessError(first_proc.returncode, first)


def fixup_permissions(directory: str) -> None:
    """Recurse down a directory tree opening permissions so that others may
    access files in the tree.
    """

    for entry in os.listdir(directory):
        path = f"{directory}/{entry}"

        st = os.lstat(path)
        mode = stat.S_IMODE(st.st_mode)
        mode |= (stat.S_IRUSR | stat.S_IRGRP | stat.S_IROTH)
        if stat.S_ISDIR(st.st_mode):
            mode |= (stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)

        if stat.S_IMODE(st.st_mode) != mode:
            verbose(f"Changing {path} from {stat.S_IMODE(st.st_mode):4o} to {mode:4o}")
            os.chmod(path, mode)

        if stat.S_ISDIR(st.st_mode):
            fixup_permissions(path)


def main():
    parser = argparse.ArgumentParser(
        description="Uncompress and unpack source archives.")
    parser.add_argument('-v', '--verbose', action='store_true',
        help="Make program more verbose.")
    parser.add_argument('-f', '--fix-permissions', action='store_true',
        help="Open permissions so that others may access unpacked files.")
    parser.add_argument('-r', '--relocate-to',
        help="Where should unpacked files be relocated.")
    parser.add_argument('file')

    args = parser.parse_args()

    if args.verbose:
        global verbose
        verbose = print

    filename = args.file if args.file.startswith("/") else f"../{args.file}"
    commands = extract_commands(filename)
    tempdir = tempfile.mkdtemp(dir='.')

    # extract the archive contents
    verbose(f"cd {tempdir}; {format_commands(commands)}")
    extract_archive(tempdir, commands)

    # open up the permissions on what we extracted
    if args.fix_permissions:
        fixup_permissions(tempdir)

    if args.relocate_to is None:
        # move everything in the tempdir here
        for entry in os.listdir(tempdir):
            path = f"{tempdir}/{entry}"
            os.renames(path, entry)
    else:
        # rename the tempdir and open it's permissions
        os.renames(tempdir, args.relocate_to)
        os.chmod(args.relocate_to, 0o0755)


if __name__ == "__main__":
    main()
