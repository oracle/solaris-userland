Use getrandom(2) on Solaris when available instead of reading
/dev/urandom directly.

Oracle bug 39671113
Upstream pull request: https://github.com/libuv/libuv/pull/5187

diff --git a/Makefile.am b/Makefile.am
index 187c4d7..44a42d2 100644
--- a/Makefile.am
+++ b/Makefile.am
@@ -534,7 +534,8 @@
                    -D_XOPEN_SOURCE=500 \
                    -D_REENTRANT
 libuv_la_SOURCES += src/unix/no-proctitle.c \
-                    src/unix/sunos.c
+                    src/unix/sunos.c \
+                    src/unix/random-getrandom.c
 endif
 
 if OS390
diff --git a/src/random.c b/src/random.c
index 74bb1a1..b8f0133 100644
--- a/src/random.c
+++ b/src/random.c
@@ -43,6 +43,6 @@ static int uv__random(void* buf, size_t buflen) {
 #elif defined(__NetBSD__)
   rc = uv__random_sysctl(buf, buflen);
-#elif defined(__FreeBSD__) || defined(__linux__)
+#elif defined(__FreeBSD__) || defined(__linux__) || defined(__sun)
   rc = uv__random_getrandom(buf, buflen);
   if (rc == UV_ENOSYS)
     rc = uv__random_devurandom(buf, buflen);
