7010804 Xorg should audit connections and disconnections.

--- xorg-server-21.1.22/configure.ac
+++ xorg-server-21.1.22/configure.ac
@@ -252,6 +252,13 @@ AC_DEFINE(HAVE_EXECINFO_H, 1, [Have exec
