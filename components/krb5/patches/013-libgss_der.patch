 /*
+ * Compatibility helpers for older Solaris consumers (e.g. libgsscred).
+ * These were historically exported as gssint_* from mechglue.
+ *
+ * Semantics expected by old callers:
+ *  - gssint_der_length_size(len): bytes needed to encode len as DER length
+ *  - gssint_put_der_length(len, &p, size): write DER length, advance *p
+ *      returns 0 on success, nonzero on failure
+ *  - gssint_get_der_length(&p, avail, &bytes): decode DER length at *p,
+ *      advance *p past the DER length, set *bytes to consumed bytes,
+ *      return length, or -1 on failure
+ */
+
+unsigned int
+gssint_der_length_size(unsigned int len)
+{
+    return (unsigned int)k5_der_len_len((size_t)len);  /* [2] */
+}
+
+int
+gssint_put_der_length(unsigned int len, unsigned char **buf,
+    unsigned int der_len_size)
+{
+    size_t llen = k5_der_len_len((size_t)len);  /* [2] */
+    unsigned char *p = *buf;
+
+    if (der_len_size != (unsigned int)llen)
+        return 1;
+
+    if (len < 128) {
+        *p++ = (unsigned char)len;
+        *buf = p;
+        return 0;
+    }
+
+    /* Long form: first byte 0x80 | (number of subsequent length bytes) */
+    *p++ = (unsigned char)(0x80 | (llen - 1));
+
+    /* Emit length bytes MSB-first (same rule as k5-der.h). */
+    for (size_t i = llen - 1; i > 0; i--) {
+        *p++ = (unsigned char)((len >> ((i - 1) * 8)) & 0xFF);
+    }
+
+    *buf = p;
+    return 0;
+}
+
+int
+gssint_get_der_length(unsigned char **buf, unsigned int avail,
+    unsigned int *bytes)
+{
+    struct k5input in;
+    size_t len, i;
+    uint8_t lenbyte;
+
+    k5_input_init(&in, *buf, (size_t)avail);
+
+    /* Decode DER length (definite form), using the same rules as k5_der_get_taglen(). */
+    lenbyte = k5_input_get_byte(&in);
+    if (in.status)
+        return -1;
+
+    if (lenbyte < 128) {
+        if (bytes != NULL)
+            *bytes = 1;
+        *buf = (unsigned char *)in.ptr;
+        return (int)lenbyte;
+    }
+
+    len = 0;
+    for (i = 0; i < (lenbyte & 0x7F); i++) {
+        if (len > (SIZE_MAX >> 8)) {
+            k5_input_set_status(&in, EOVERFLOW);
+            break;
+        }
+        len = (len << 8) | k5_input_get_byte(&in);
+    }
+
+    if (in.status)
+        return -1;
+
+    if (bytes != NULL)
+        *bytes = 1 + (lenbyte & 0x7F);
+
+    *buf = (unsigned char *)in.ptr;
+
+    if (len > INT_MAX)
+        return -1;
+
+    return (int)len;
+}
+
+/*
  * The following mechanisms do not always identify themselves
  * per the GSS-API specification, when interoperating with MS
  * peers. We include the OIDs here so we do not have to ilnk
