     destructors_set[keynum] = 1;
     destructors[keynum] = destructor;
     LeaveCriticalSection(&key_lock);
@@ -348,7 +350,8 @@ LeaveCriticalSection(&key_lock);
 #else /* POSIX */
 
     k5_mutex_lock(&key_lock);
-    assert(destructors_set[keynum] == 0);
+    assert((destructors_set[keynum] == 0) ||
