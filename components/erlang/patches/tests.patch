Fix erlang tests so that they are always done in the same order and
therefore generate test results that we can successfully compare
against a master test results file.

GNU make v3.82 introduced a change that caused this failure:

  https://lists.gnu.org/archive/html/info-gnu/2010-07/msg00023.html

  * WARNING: Future backward-incompatibility!
    Wildcards are not documented as returning sorted values, but up to and
    including this release the results have been sorted and some makefiles are
    apparently depending on that.  In the next release of GNU make, for
    performance reasons, we may remove that sorting.  If your makefiles
    require sorted results from wildcard expansions, use the $(sort ...)
    function to request it explicitly.
 
This change will be passed upstream.

--

Add smoke_test target.

--- otp_src_28.4.1/Makefile.in
+++ otp_src_28.4.1/Makefile.in
@@ -830,7 +830,7 @@ # --------------------------------------
 
 TEST_DIRS := \
 	lib/common_test/test_server \
-	$(wildcard lib/*/test) \
+	$(sort $(wildcard lib/*/test)) \
 	erts/test \
 	erts/epmd/test \
 	erts/emulator/test
@@ -983,6 +983,14 @@ test: all release release_tests
 	MAKE="$(MAKE)" \
 	  $(ERL_TOP)/make/test_target_script.sh $(ERL_TOP)
 
+# Minimal testing per: https://www.erlang.org/doc/system/install.html#testing
+# tmux is workaround for internal BOB builds (erlang exits early when started via python).
+smoke_test: all release release_tests
+	cd $(ERL_TOP)/release/tests/test_server ; \
+	MAKE="$(MAKE)" \
+	  tmux -L "test_$$$$_tmux" new-session -d -s test '$(ERL_TOP)/bin/erl -s ts install -s ts smoke_test batch -s init stop >>smoke_test.log 2>&1'; \
+	while tmux -L "test_$$$$_tmux" has-session -t test 2>/dev/null; do sleep 1; done; cat smoke_test.log
+
 ifeq ($(TYPE),)
 dialyzer: all
 	$(ERL_TOP)/scripts/run-dialyzer
