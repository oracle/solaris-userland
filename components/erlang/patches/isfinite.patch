Allow isfinite() detection on Solaris.

https://github.com/erlang/otp/pull/10965

--- otp_src_28.4.1/erts/configure.ac
+++ otp_src_28.4.1/erts/configure.ac
@@ -2217,7 +2217,7 @@ AC_MSG_RESULT(no)
 fi
 
 AC_MSG_CHECKING([for isfinite])
-AC_LINK_IFELSE([AC_LANG_PROGRAM([[#include <math.h>]], [[isfinite(0);]])],[have_isfinite=yes],[have_isfinite=no])
+AC_LINK_IFELSE([AC_LANG_PROGRAM([[#include <math.h>]], [[isfinite(0.0);]])],[have_isfinite=yes],[have_isfinite=no])
 
 if test $have_isfinite = yes; then
     AC_DEFINE(HAVE_ISFINITE,[1],
--- otp_src_28.4.1/lib/common_test/test_server/configure.ac
+++ otp_src_28.4.1/lib/common_test/test_server/configure.ac
@@ -353,7 +353,7 @@ # Check for isfinite
 #--------------------------------------------------------------------
 
 AC_MSG_CHECKING([for isfinite])
-AC_LINK_IFELSE([AC_LANG_PROGRAM([[#include <math.h>]], [[isfinite(0);]])],[have_isfinite=yes],[have_isfinite=no])
+AC_LINK_IFELSE([AC_LANG_PROGRAM([[#include <math.h>]], [[isfinite(0.0);]])],[have_isfinite=yes],[have_isfinite=no])
 
 if test $have_isfinite = yes; then
     AC_DEFINE(HAVE_ISFINITE,1)
