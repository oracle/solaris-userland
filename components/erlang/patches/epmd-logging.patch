The customer oriented patch that adds an extra
option to epmd daemon that disables logging
to system logs.

Generally, it is not a good idea to disable
system logging, therefore, the patch is not
suitable for upstream.

--- otp_src_28.4.1/erts/epmd/src/epmd.c
+++ otp_src_28.4.1/erts/epmd/src/epmd.c
@@ -126,6 +126,7 @@ g->port           = get_port_no();
     g->debug          = 0;
 
     g->silent         = 0; 
+    g->logging        = 1;
     g->is_daemon      = 0;
     g->brutal_kill    = check_relaxed();
     g->packet_timeout = CLOSE_TIMEOUT; /* Default timeout */
@@ -217,6 +218,9 @@ } else if (strcmp(argv[0], "-systemd") =
             g->is_systemd = 1;
             argv++; argc--;
 #endif /* HAVE_SYSTEMD_DAEMON */
+	} else if (strcmp(argv[0], "-disable_syslog") == 0) {
+    g->logging = 0;
+    argv++; argc--;
 	} else
 	    usage(g);
     }
@@ -255,6 +259,7 @@ /* fork to make sure first child is not
     if (( child_pid = fork()) < 0)
       {
 #ifdef HAVE_SYSLOG_H
+	if (g->logging)
 	syslog(LOG_ERR,"erlang mapper daemon can't fork %m");
 #endif
 	epmd_cleanup_exit(g,1);
@@ -281,6 +286,7 @@ /* We don't want to be session leader so
     if ((child_pid = fork()) < 0)
       {
 #ifdef HAVE_SYSLOG_H
+	if (g->logging)
 	syslog(LOG_ERR,"erlang mapper daemon can't fork 2'nd time %m");
 #endif
 	epmd_cleanup_exit(g,1);
@@ -453,6 +459,7 @@ #ifdef HAVE_SYSLOG_H
       if (onsyslog)
 	{
 	  erts_vsnprintf(buf, DEBUG_BUFFER_SIZE, format, args);
+	  if (g->logging)
 	  syslog(LOG_ERR,"epmd: %s",buf);
 	}
 #endif
--- otp_src_28.4.1/erts/epmd/src/epmd_int.h
+++ otp_src_28.4.1/erts/epmd/src/epmd_int.h
@@ -343,6 +343,7 @@ typedef struct {
   int port;
   int debug;
   int silent; 
+  int logging;
   int is_daemon;
   int brutal_kill;
   unsigned packet_timeout;
