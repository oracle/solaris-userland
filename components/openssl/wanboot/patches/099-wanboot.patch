         port = ++p;
     /* remaining port spec handling is also done for the default values */
     /* make sure a decimal port number is given */
-    if (sscanf(port, "%u", &portnum) <= 0 || portnum > 65535) {
+    if (!parse_port(port, &portnum)) {
         ERR_raise_data(ERR_LIB_HTTP, HTTP_R_INVALID_PORT_NUMBER, "%s", port);
         goto err;
     }
@@ -202,6 +219,7 @@ int OSSL_HTTP_parse_url(const char *url, int *pssl, char **puser, char **phost,
 {
     char *scheme, *port;
     int ssl = 0, portnum;
+    unsigned int uportnum;
 
     init_pstring(pport);
     if (pssl != NULL)
@@ -227,8 +245,9 @@ int OSSL_HTTP_parse_url(const char *url, int *pssl, char **puser, char **phost,
         /* set default port */
