# crypto/sleep.c:
# Sleep syscalls are unavailable in the boot environment. Make OSSL_sleep() a
# no-op for _BOOT instead of using nanosleep(), sleep(), or fallback code that
# still references sleep().
--- openssl-3.5.6/crypto/sleep.c
+++ openssl-3.5.6/crypto/sleep.c
@@ -12,7 +12,13 @@
 #include "internal/time.h"
 
 /* system-specific variants defining OSSL_sleep() */
-#if (defined(OPENSSL_SYS_UNIX) || defined(__DJGPP__)) && !defined(OPENSSL_USE_SLEEP_BUSYLOOP)
+#if defined(_BOOT)
+static void ossl_sleep_millis(uint64_t millis)
+{
+    (void)millis;
+}
+
+#elif (defined(OPENSSL_SYS_UNIX) || defined(__DJGPP__)) && !defined(OPENSSL_USE_SLEEP_BUSYLOOP)
 
 #if defined(OPENSSL_USE_USLEEP) \
     || defined(__DJGPP__)       \
@@ -112,6 +118,9 @@ void OSSL_sleep(uint64_t millis)
 
 void OSSL_sleep(uint64_t millis)
 {
+#ifdef _BOOT
+    (void)millis;
+#else
     OSSL_TIME now = ossl_time_now();
     OSSL_TIME finish = ossl_time_add(now, ossl_ms2time(millis));
     uint64_t left = millis;
@@ -132,4 +141,5 @@ void OSSL_sleep(uint64_t millis)
         now = ossl_time_now();
         left = ossl_time2ms(ossl_time_subtract(finish, now));
     } while (ossl_time_compare(now, finish) < 0);
+#endif
 }


