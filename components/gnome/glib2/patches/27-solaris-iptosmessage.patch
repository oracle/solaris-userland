Solaris does not provide IP_RECVTOS or IPV6_RECVTCLASS, so the
iptosmessage test cannot compile. Skip it as upstream already does on
other unsupported systems.

The patch was offered upstream at:
https://gitlab.gnome.org/GNOME/glib/-/work_items/3994

--- a/gio/tests/iptosmessage.c
+++ b/gio/tests/iptosmessage.c
@@ -25,7 +25,7 @@
 
 /* See the g_test_skip() calls below for platform-specific reasons why this test
  * code sometimes needs to be skipped. */
-#if ! (defined(G_OS_WIN32) || defined(__APPLE__) || defined(__GNU__))
+#if ! (defined(G_OS_WIN32) || defined(__APPLE__) || defined(__GNU__) || defined(__sun__))
 
 static GSocketControlMessage *
 send_recv_control_message (GSocketFamily family, GSocketControlMessage *msg)
@@ -117,6 +117,8 @@ test_ip_tos (void)
   g_test_skip ("IP_TOS not supported on macOS.");
 #elif defined(__GNU__)
   g_test_skip ("IP_RECVTOS not supported on Hurd");
+#elif defined(__sun__)
+  g_test_skip ("IP_RECVTOS not supported on Solaris");
 #else
   GIPTosMessage *smsg;
   GIPTosMessage *rmsg;
@@ -141,6 +143,8 @@ test_ipv6_tclass (void)
   g_test_skip ("IPV6_TCLASS not supported on macOS.");
 #elif defined(__GNU__)
   g_test_skip ("IPV6_RECVTCLASS not supported on Hurd");
+#elif defined(__sun__)
+  g_test_skip ("IPV6_RECVTCLASS not supported on Solaris");
 #else
   GIPv6TclassMessage *smsg;
   GIPv6TclassMessage *rmsg;
