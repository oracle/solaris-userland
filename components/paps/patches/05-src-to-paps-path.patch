+def source_to_pango_markup(fn, source_lang, verbose=False):
+  source = Path(fn).read_text(errors='ignore')
+  try:
+    lexer = guess_lexer_for_filename(fn, source) if source_lang is None else get_lexer_by_name(source_lang)
+  except ClassNotFound:
+    if verbose:
+      sys.stderr.write(f'No lexer found for {fn}, using plain text\n')
+    lexer = TextLexer()
+  markup = highlight(source, lexer, PangoMarkupFormatter()).strip()
+  if markup.startswith('<tt>') and markup.endswith('</tt>'):
+    markup = markup[4:-5]
+  return re.sub(r'<span fgcolor="#bbbbbb">(\s+)</span>', r'\1', markup)
 
