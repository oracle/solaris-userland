+++ gcc-16.1.0/gcc/testsuite/gcc.target/i386/saveargs-argstruct.c
@@ -0,0 +1,41 @@
+/* { dg-do run { target { ! ia32 } } } */
+/* { dg-options "-O2 -msave-args" } */
+
+#include "saveargs.h"
+
+typedef struct arg {
+	uint64_t arg1;
+	uint64_t arg2;
+} arg_t;
+
+int test_argstruct(arg_t as, uint64_t a2, uint64_t a3, uint64_t a4, uint64_t a5, uint64_t a6)
+{
+	int ret = 0;
+
+	/*
+	 * This struct should be stored in argument registers as well.
+	 */
+	uint64_t in_vec[6] = {as.arg1, as.arg2, a2, a3, a4, a5};
+
+	READ_RBP();
+
+	COMPARE_SAVED(in_vec, 6, ret);
+
+	return ret;
+}
+
+int main(void)
+{
+	int ret;
+
+	GET_RAND_ARG(arg);
+
+	arg_t argstruct = {
+		.arg1 = arg,
+		.arg2 = arg+1
+	};
+
+	ret = test_argstruct(argstruct, arg+2, arg+3, arg+4, arg+5, arg+6);
+
+	return ret;
+}
