@@ -0,0 +1,28 @@
+/* { dg-do run { target { ! ia32 } } } */
+/* { dg-options "-O2 -msave-args" } */
+
+#include "saveargs.h"
+
+__attribute__((noinline))
+int test_1arg(uint64_t a1)
+{
+	int ret = 0;
+	uint64_t in_vec[1] = {a1};
+
+	READ_RBP();
+
+	COMPARE_SAVED(in_vec, 1, ret);
+
+	return ret;
+}
+
+int main(void)
+{
+	int ret;
+
+	GET_RAND_ARG(arg);
+
+	ret = test_1arg(arg);
+
+	return ret;
+}
