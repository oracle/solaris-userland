+ret_t test_retstruct(uint64_t a1, uint64_t a2, uint64_t a3, uint64_t a4, uint64_t a5)
+{
+       ret_t retstruct = {
+               .arg1 = a1,
+               .arg2 = a2,
+               .retval = 0
+       };
+
+       /*
+        * All five arguments should be stored in registers.
