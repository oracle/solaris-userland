Handle Python int values when converting Gst.Fraction to GValue.

On Python 3.11, int objects do not provide is_integer().  Gst.Fraction stores
integer numerator and denominator values, so check PyLong first and avoid
dereferencing a NULL result from PyObject_CallMethod().

--- gst-python-1.28.2/gi/overrides/gstmodule.c
+++ gst-python-1.28.2/gi/overrides/gstmodule.c
@@ -104,60 +104,75 @@ Py_DECREF (args);
   return fraction;
 }
 
+static gboolean
+gi_gst_fraction_component_to_long (PyObject * object, const gchar * name,
+    glong * component)
+{
+  PyObject *is_integer;
+
+  if (PyLong_Check (object)) {
+    *component = PyLong_AsLong (object);
+    if (PyErr_Occurred ())
+      return FALSE;
+  } else {
+    is_integer = PyObject_CallMethod (object, "is_integer", NULL);
+    if (is_integer == NULL)
+      return FALSE;
+
+    if (is_integer != Py_True) {
+      PyErr_Format (PyExc_TypeError, "%s %f is not an integer.", name,
+          PyFloat_AsDouble (object));
+      Py_DECREF (is_integer);
+      return FALSE;
+    }
+    Py_DECREF (is_integer);
+
+    *component = PyFloat_AsDouble (object);
+    if (PyErr_Occurred ())
+      return FALSE;
+  }
+
+  if (*component < -G_MAXINT || *component > G_MAXINT) {
+    PyErr_Format (PyExc_ValueError,
+        "%s %" G_GINT64_FORMAT " is out of bound. [-%d - %d]",
+        name, *component, G_MAXINT, G_MAXINT);
+    return FALSE;
+  }
+
+  return TRUE;
+}
+
