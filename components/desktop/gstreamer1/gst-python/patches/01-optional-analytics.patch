 endif
 
 gstpython = python.extension_module('_gi_gst',
@@ -21,14 +23,6 @@ include_directories : [configinc],
     dependencies : [gst_dep_for_gi, python_dep, pygobject_dep],
 )
 
-gstanalyticspython = python.extension_module ('_gi_gst_analytics',
