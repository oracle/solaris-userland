+pysources = ['Gst.py', 'GstPbutils.py', 'GstVideo.py', 'GstAudio.py', 'GstApp.py']
+if gstbad_dep.found()
+  pysources += ['GstAnalytics.py']
+endif
 python.install_sources(pysources,
   pure : false,
   subdir: 'gi/overrides',
@@ -9,7 +12,6 @@ if host_system == 'windows'
