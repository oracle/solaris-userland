 TEST_P(TlsConnectDatagramPre13, DropClientSecondFlightThrice) {
   client_->SetFilter(std::make_shared<SelectiveDropFilter>(0xe));
-  Connect();
+  ConnectWithDtlsTimers();
 }
 
