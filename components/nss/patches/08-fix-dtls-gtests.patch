Fix unstable DTLS gtests.

Drive DTLS retransmit tests with the test harness DTLS timers instead of
depending on wall-clock scheduling.  The malformed DTLS 1.3 KeyUpdate length
tests send invalid handshake fragments, so expect NSS to reject them as
malformed handshakes instead of trying to exchange application data afterwards.

--- nss-3.123.1/nss/gtests/ssl_gtest/tls_connect.h
+++ nss-3.123.1/nss/gtests/ssl_gtest/tls_connect.h
@@ -71,8 +71,11 @@
   void StartConnect();
   // Run the handshake.
   void Handshake();
+  // Run the handshake, explicitly driving DTLS retransmit timers.
+  void HandshakeWithDtlsTimers();
   // Connect and check that it works.
   void Connect();
+  void ConnectWithDtlsTimers();
   // Check that the connection was successfully established.
   void CheckConnected();
   // Connect and expect it to fail.
--- nss-3.123.1/nss/gtests/ssl_gtest/tls_connect.cc
+++ nss-3.123.1/nss/gtests/ssl_gtest/tls_connect.cc
@@ -413,6 +413,34 @@ void TlsConnectTestBase::Handshake() {
                    5000);
 }
 
+void TlsConnectTestBase::HandshakeWithDtlsTimers() {
+  client_->SetServerKeyBits(server_->server_key_bits());
+  client_->Handshake();
+  server_->Handshake();
+
+  if (variant_ == ssl_variant_datagram) {
+    for (size_t i = 0;
+         i < 20 && (client_->state() == TlsAgent::STATE_CONNECTING ||
+                    server_->state() == TlsAgent::STATE_CONNECTING);
+         ++i) {
+      ShiftDtlsTimers();
+      client_->Handshake();
+      server_->Handshake();
+    }
+  }
+
+  ASSERT_TRUE_WAIT((client_->state() != TlsAgent::STATE_CONNECTING) &&
+                       (server_->state() != TlsAgent::STATE_CONNECTING),
+                   5000);
+}
+
+void TlsConnectTestBase::ConnectWithDtlsTimers() {
+  StartConnect();
+  client_->MaybeSetResumptionToken();
+  HandshakeWithDtlsTimers();
+  CheckConnected();
+}
+
 void TlsConnectTestBase::EnableExtendedMasterSecret() {
   client_->EnableExtendedMasterSecret();
   server_->EnableExtendedMasterSecret();
