+static int get_one_rlimit(int resource, rlim_t *limit, const char *name) {
+    struct rlimit rl = {0,};
+    int r;
+
+    r = getrlimit(resource, &rl);
+    if (r < 0) {
+        avahi_log_warn("getrlimit(%s) failed: %s", name, strerror(errno));
+    } else {
+        *limit = rl.rlim_cur;
+    }
+
+    return r;
+}
+
+static unsigned get_simple_protocol_max_clients(void) {
+    rlim_t nofiles = MAX_NOFILE_LIMIT;
+    rlim_t max_clients;
+
+    if (get_one_rlimit(RLIMIT_NOFILE, &nofiles, "RLIMIT_NOFILE") < 0)
+        return MAX_NOFILE_LIMIT;
+
+    if (nofiles == RLIM_INFINITY)
+        return MAX_NOFILE_LIMIT;
+
+    /* Use about 3/4 of the live file descriptor limit for simple clients.
+     * Keep the rest for the daemon's sockets and other descriptors. */
+    max_clients = nofiles / 4 * 3;
+    if (max_clients > MAX_NOFILE_LIMIT)
+        return MAX_NOFILE_LIMIT;
+
+    return (unsigned) max_clients;
+}
+
 static void set_one_rlimit(int resource, rlim_t limit, const char *name) {
     struct rlimit rl;
     rl.rlim_cur = rl.rlim_max = limit;
