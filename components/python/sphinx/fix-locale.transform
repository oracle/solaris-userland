# Gate locale tranforms treat everything under 'locale' directory as a locale
# name. __init__ and __pycache__ is an exception we need to remove.

<transform facet.locale.__init__=.* -> delete facet.locale.__init__ .*>
<transform facet.locale.__pycache__=.* -> delete facet.locale.__pycache__ .*>
